# Claude / Anthropic API
ANTHROPIC_API_KEY=sk-ant-여기에_API키_입력

# WordPress 설정
WP_URL=https://your-site.com          # 사이트 주소 (끝에 / 없이)
WP_USER=your_username                  # 워드프레스 관리자 아이디
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx   # Application Password (설정→사용자→프로필에서 생성)

# 포스팅 설정 (선택)
WP_CATEGORY_ID=1                       # 기본 카테고리 ID (비워두면 미분류)
WP_STATUS=publish                      # publish(즉시발행) 또는 draft(임시저장)

# 크롤링 설정 (선택)
RSS_FEEDS=https://feeds.feedburner.com/example1,https://example.com/rss  # 쉼표로 구분
CRAWL_KEYWORDS=경제,부동산,주식         # 쉼표로 구분된 수집 키워드
